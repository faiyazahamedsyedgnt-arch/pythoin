import threading
count = 0 
lock=threading.Lock()

def increament():
    global count
    for i in range(10000):
        with lock:
        #critical section
            count +=1
    
t1 =threading.Thread(target=increament)        
t2 =threading.Thread(target=increament)

t1.start()
t2.start()

t1.join()
t2.join()
print(count)



